{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BhavaSourceReference",
  "description": "A verified source reference linking Bhāva content to its scriptural origin.",
  "type": "object",
  "required": ["scripture", "reference_text", "verified"],
  "properties": {
    "scripture": {
      "type": "string",
      "description": "Scripture name, e.g. 'Krishna Book', 'Śrīmad-Bhāgavatam', 'Bhagavad-gītā'."
    },
    "reference_text": {
      "type": "string",
      "description": "Human-readable reference, e.g. 'Chapter 12: The Stealing of the Boys and Calves'."
    },
    "work": {
      "type": ["string", "null"],
      "description": "Full work title when distinct from scripture shorthand."
    },
    "author": {
      "type": ["string", "null"],
      "description": "Author or compiler of the cited work."
    },
    "canto": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 12,
      "description": "Canto number for Bhāgavatam references."
    },
    "chapter": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Chapter number within the canto or scripture."
    },
    "chapter_title": {
      "type": ["string", "null"]
    },
    "passage_start": {
      "type": ["string", "null"],
      "description": "Human-readable passage start boundary."
    },
    "passage_end": {
      "type": ["string", "null"],
      "description": "Human-readable passage end boundary."
    },
    "verse_start": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Starting verse number."
    },
    "verse_end": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Ending verse number."
    },
    "vedabase_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Verified Vedabase URL for the chapter/canto page. Never invent."
    },
    "local_pdf_page_start": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Private local PDF page start; never served publicly."
    },
    "local_pdf_page_end": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Private local PDF page end; never served publicly."
    },
    "edition": {
      "type": ["string", "null"],
      "description": "Specific edition or publication referenced."
    },
    "permissions_status": {
      "type": "string",
      "enum": ["licensed", "public-domain", "excerpt-needs-review", "needs-review"]
    },
    "provenance": {
      "type": "string",
      "enum": ["bhava-original", "bbt-source-derived", "third-party"]
    },
    "review_status": {
      "type": "string",
      "enum": ["reviewed", "needs_review", "pending"]
    },
    "verified": {
      "type": "boolean",
      "description": "Whether this reference has been verified against the source text."
    },
    "verified_by": {
      "type": ["string", "null"],
      "description": "Name of the reviewer who verified the reference."
    },
    "verified_at": {
      "type": ["string", "null"],
      "format": "date",
      "description": "ISO date of verification."
    },
    "reviewer": {
      "type": ["string", "null"]
    },
    "reviewed_date": {
      "type": ["string", "null"],
      "format": "date"
    }
  },
  "additionalProperties": false
}
