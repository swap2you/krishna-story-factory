{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BhavaSourceReference",
  "description": "A verified source reference linking Bhāva content to its scriptural origin.",
  "type": "object",
  "required": ["scripture", "reference_text", "verified"],
  "properties": {
    "scripture": {
      "type": "string",
      "description": "Scripture name, e.g. 'Krishna Book', 'Śrīmad-Bhāgavatam', 'Bhagavad-gītā'."
    },
    "reference_text": {
      "type": "string",
      "description": "Human-readable reference, e.g. 'Chapter 12: The Stealing of the Boys and Calves'."
    },
    "canto": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 12,
      "description": "Canto number for Bhāgavatam references."
    },
    "chapter": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Chapter number within the canto or scripture."
    },
    "verse_start": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Starting verse number."
    },
    "verse_end": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "Ending verse number."
    },
    "edition": {
      "type": ["string", "null"],
      "description": "Specific edition or publication referenced."
    },
    "verified": {
      "type": "boolean",
      "description": "Whether this reference has been verified against the source text."
    },
    "verified_by": {
      "type": ["string", "null"],
      "description": "Name of the reviewer who verified the reference."
    },
    "verified_at": {
      "type": ["string", "null"],
      "format": "date",
      "description": "ISO date of verification."
    }
  },
  "additionalProperties": false
}
