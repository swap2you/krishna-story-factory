# Krishna Story Factory local settings
APP_TIMEZONE=America/New_York
OUTPUT_ROOT=output

# OpenAI text generation
OPENAI_TEXT_ENABLED=false
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4
OPENAI_REPAIR_MODEL=gpt-5.4
OPENAI_VISUAL_QA_MODEL=gpt-5.4-mini

# OpenAI image generation
OPENAI_IMAGE_ENABLED=false
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=high
OPENAI_IMAGE_FORMAT=png
OPENAI_IMAGE_OUTPUT_FORMAT=png

IMAGE_REFERENCE_LINE_ART=assets/reference/approved_line_art.png
IMAGE_REFERENCE_POSTER=assets/reference/approved_poster.png
IMAGE_REFERENCE_REQUIRED=false
IMAGE_CANDIDATES_PER_TYPE=2
IMAGE_MAX_REPAIR_ROUNDS=2
IMAGE_MIN_ACCEPTANCE_SCORE=86

PIPELINE_MAX_REPAIR_ATTEMPTS=4
DEBUG_ARTIFACTS=false

# ElevenLabs narration
ELEVENLABS_ENABLED=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_STABILITY=0.38
ELEVENLABS_SIMILARITY_BOOST=0.78
ELEVENLABS_STYLE=0.0
ELEVENLABS_SPEED=0.94
ELEVENLABS_USE_SPEAKER_BOOST=true
ELEVENLABS_PRONUNCIATION_DICTIONARY_ID=
ENABLE_AMBIENT_AUDIO=false
ELEVENLABS_SFX_ENABLED=false
AMBIENT_AUDIO_MIX_LEVEL=0.12

# Sender control
WHATSAPP_SEND_ENABLED=false
TELEGRAM_SEND_ENABLED=false
WHATSAPP_SENDER_TYPE=manual
WHATSAPP_WEB_TEST_DIR=whatsapp_test_outbox

# WhatsApp Business Cloud API
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_TEST_RECIPIENT_PHONE=
WHATSAPP_TEMPLATE_NAME=daily_krishna_story
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_RECIPIENTS_CSV=input/whatsapp_recipients.csv

# Legacy aliases (optional)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TARGET_PHONE=
WHATSAPP_LANGUAGE_CODE=en_US

# Telegram fallback sender
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack fallback sender
SLACK_WEBHOOK_URL=

# Discord fallback sender
DISCORD_WEBHOOK_URL=

# Audio fallback (test/debug only)
ALLOW_PLACEHOLDER_AUDIO=false

# Package publishing / Google Drive
PACKAGE_PUBLISH_MODE=local
GOOGLE_DRIVE_UPLOAD_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_FOLDER_URL=
GOOGLE_DRIVE_CREDENTIALS_FILE=credentials/google_drive_oauth_client.json
GOOGLE_DRIVE_TOKEN_FILE=credentials/google_drive_token.json
GOOGLE_DRIVE_LOCAL_SYNC_ROOT=
GOOGLE_DRIVE_SHARE_ROLE=reader
GOOGLE_DRIVE_OVERWRITE_EXISTING=false
PACKAGE_PUBLIC_LINK=
